# Copy to .env and fill in. .env is gitignored.

# St. Louis Fed FRED / ALFRED — required for AHETPI, M2, DFII10, DTWEXM,
# VIXCLS, and the gold London PM fix (GOLDPMGBD228NLBM).
# Free API key: https://fredaccount.stlouisfed.org/apikeys
FRED_API_KEY=

# U.S. Energy Information Administration — required for Brent spot
# (PET.RBRTE.D), the basis for N_Energy. Free key:
# https://www.eia.gov/opendata/register.php
EIA_API_KEY=
