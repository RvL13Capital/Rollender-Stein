# Copy to .env and fill in. .env is gitignored.

# St. Louis Fed FRED — required for AHETPI (N_Time), WM2NS (US M2 in N_Liq),
# the BIS broad money series MABMM301{EZ,JP}M{189,657}S (EZ/JP M3 in N_Liq),
# DEXUSEU + DEXJPUS (FX in N_Liq), and DFII10 / DTWEXBGS / VIXCLS (Phase 4.5
# Kalman diagnostic exog). Free API key:
# https://fredaccount.stlouisfed.org/apikeys
FRED_API_KEY=

# U.S. Energy Information Administration — required for Brent spot
# (RBRTE), the basis for N_Energy. Free key:
# https://www.eia.gov/opendata/register.php
EIA_API_KEY=

# Yahoo Finance is the gold spot source post-audit-patch-06: GC=F front-month
# futures used as a spot proxy (LBMA series GOLDPMGBD228NLBM was removed
# from FRED in 2017, no free spot replacement exists). Yahoo Finance has no
# API key.
